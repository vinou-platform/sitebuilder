{% if section.flash is defined and section.flash %}
  <div class="alert alert-{{ section.flash.type == 'error' ? 'error' : 'success' }}">
    {{ section.flash.message }}
  </div>
{% endif %}

{% if section.message %}
  <div class="alert alert-success">{{ section.message }}</div>
{% endif %}

<div class="content-header">
  <h2>System</h2>
  <span class="subtitle">Cache-Verwaltung, Umgebung &amp; Abhängigkeiten</span>
</div>

<div class="card">
  <div class="card-header">Vinou API</div>
  <div class="card-body">
    <div class="cache-grid cache-grid--api">
      <div class="cache-card">
        <h3>API-Verbindung</h3>
        <p>Live-Verbindung zur Vinou-API prüfen und Session erneuern</p>
        <button hx-get="/system/cache?action=testApi"
                hx-target="#api-test-result"
                hx-swap="innerHTML"
                hx-indicator="#api-test-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block">Verbindung prüfen</button>
        <div id="api-test-progress" class="cache-progress">
          <div class="cache-progress-bar"></div>
        </div>
      </div>
      <div id="api-test-result" class="cache-result-area cache-result-area--panel"></div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">Instagram</div>
  <div class="card-body">
    <div class="cache-grid cache-grid--api">
      <div class="cache-card">
        <h3>App-Zugangsdaten</h3>
        <p>App ID und App Secret aus dem <a href="https://developers.facebook.com/apps" target="_blank" rel="noopener" style="color:inherit">Meta Developer Portal</a>.</p>
        <form method="post" action="/system/instagram/credentials">
          <input type="hidden" name="_csrf_token" value="{{ admin.csrfToken }}">
          <div class="form-group" style="margin-bottom:0.5rem">
            <label class="form-label">App ID</label>
            <input type="text" name="app_id" class="form-control"
                   value="{{ section.instagramStatus.appId ?? '' }}"
                   placeholder="123456789012345">
          </div>
          <div class="form-group" style="margin-bottom:0.75rem">
            <label class="form-label">App Secret</label>
            <input type="password" name="app_secret" class="form-control"
                   placeholder="{{ section.instagramStatus.appConfigured ? '••••••••' : 'abc123…' }}">
          </div>
          <button type="submit" class="btn btn-ghost btn-block">Speichern</button>
        </form>
      </div>
      {% include 'Admin/Fragment/InstagramStatus.twig' with {'admin': section.instagramStatus} %}
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">Cache</div>
  <div class="card-body">
    <div class="cache-grid">

      <div class="cache-card">
        <h3>Bilder-Cache</h3>
        <p>Cache/Images</p>
        <button hx-get="/system/cache?action=clearImages"
                hx-target="#cache-images-result"
                hx-swap="innerHTML"
                hx-indicator="#cache-images-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block">Leeren</button>
        <button hx-get="/system/cache?action=warmupImages"
                hx-target="#cache-images-result"
                hx-swap="innerHTML"
                hx-indicator="#cache-images-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block" style="margin-top:0.375rem">Aufwärmen</button>
        <div id="cache-images-progress" class="cache-progress">
          <div class="cache-progress-bar"></div>
        </div>
        <div id="cache-images-result" class="cache-result-area"></div>
      </div>

      <div class="cache-card">
        <h3>Instagram-Cache</h3>
        <p>Cache/Instagram</p>
        <button hx-get="/system/cache?action=clearInstagram"
                hx-target="#cache-instagram-result"
                hx-swap="innerHTML"
                hx-indicator="#cache-instagram-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block">Leeren</button>
        <div id="cache-instagram-progress" class="cache-progress">
          <div class="cache-progress-bar"></div>
        </div>
        <div id="cache-instagram-result" class="cache-result-area"></div>
      </div>

      <div class="cache-card">
        <h3>PDF-Cache</h3>
        <p>Cache/PDF</p>
        <button hx-get="/system/cache?action=clearPdf"
                hx-target="#cache-pdf-result"
                hx-swap="innerHTML"
                hx-indicator="#cache-pdf-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block">Leeren</button>
        <button hx-get="/system/cache?action=warmupPdf"
                hx-target="#cache-pdf-result"
                hx-swap="innerHTML"
                hx-indicator="#cache-pdf-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block" style="margin-top:0.375rem">Aufwärmen</button>
        <div id="cache-pdf-progress" class="cache-progress">
          <div class="cache-progress-bar"></div>
        </div>
        <div id="cache-pdf-result" class="cache-result-area"></div>
      </div>

    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">PHP &amp; System</div>
  <div class="card-body" style="padding:0;">
    <table class="env-table">
      <thead>
        <tr>
          <th>Komponente</th>
          <th>Status</th>
          <th>Detail</th>
        </tr>
      </thead>
      <tbody>
        {% for key, check in section.environment %}
          <tr>
            <td style="font-weight:600;">{{ check.label }}</td>
            <td>
              <span class="status">
                <span class="status-dot {{ check.available ? 'status-ok' : 'status-fail' }}"></span>
                {{ check.available ? 'OK' : 'Fehlt' }}
              </span>
            </td>
            <td>{{ check.detail }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% if section.vinouPackages is defined and section.vinouPackages|length > 0 %}
<div class="card">
  <div class="card-header">Vinou-Pakete</div>
  <div class="card-body" style="padding:0;">
    <table class="env-table">
      <thead>
        <tr>
          <th>Paket</th>
          <th>Version</th>
        </tr>
      </thead>
      <tbody>
        {% for pkg in section.vinouPackages %}
          <tr>
            <td style="font-family:'SFMono-Regular',Consolas,monospace;font-size:0.8125rem;">{{ pkg.name }}</td>
            <td><span class="badge badge-get" style="font-size:0.75rem">{{ pkg.version }}</span></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
