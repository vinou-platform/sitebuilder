{% if section.flash is defined and section.flash %}
  <div class="alert alert-{{ section.flash.type == 'error' ? 'error' : 'success' }}">
    {{ section.flash.message }}
  </div>
{% endif %}

{% if section.message %}
  <div class="alert alert-success">{{ section.message }}</div>
{% endif %}

<div class="content-header">
  <h2>System</h2>
  <span class="subtitle">Cache-Verwaltung, Umgebung &amp; Abhängigkeiten</span>
</div>

<div class="card">
  <div class="card-header">Cache leeren</div>
  <div class="card-body">
    <div class="cache-grid">
      {% for type, label in {'Images': 'Bilder-Cache', 'Instagram': 'Instagram-Cache', 'PDF': 'PDF-Cache'} %}
        <div class="cache-card">
          <h3>{{ label }}</h3>
          <p>Cache/{{ type }}</p>
          <button hx-get="/system/cache?action=clear{{ type }}"
                  hx-target="#clear-{{ type|lower }}-result"
                  hx-swap="innerHTML"
                  hx-indicator="#clear-{{ type|lower }}-progress"
                  hx-disabled-elt="this"
                  class="btn btn-ghost btn-block">Leeren</button>
          <div id="clear-{{ type|lower }}-progress" class="cache-progress">
            <div class="cache-progress-bar"></div>
          </div>
          <div id="clear-{{ type|lower }}-result" class="cache-result-area"></div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">Cache Warm-up</div>
  <div class="card-body">
    <div class="cache-grid">
      <div class="cache-card">
        <h3>Bildcache aufwärmen</h3>
        <p>Alle Produkt­bilder von der API laden, cachen und als WebP konvertieren</p>
        <button hx-get="/system/cache?action=warmupImages"
                hx-target="#warmup-img-result"
                hx-swap="innerHTML"
                hx-indicator="#warmup-img-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block">Starten</button>
        <div id="warmup-img-progress" class="cache-progress">
          <div class="cache-progress-bar"></div>
        </div>
        <div id="warmup-img-result" class="cache-result-area"></div>
      </div>
      <div class="cache-card">
        <h3>PDF-Cache aufwärmen</h3>
        <p>Alle Wein-Expertise-PDFs von der API laden und lokal cachen</p>
        <button hx-get="/system/cache?action=warmupPdf"
                hx-target="#warmup-pdf-result"
                hx-swap="innerHTML"
                hx-indicator="#warmup-pdf-progress"
                hx-disabled-elt="this"
                class="btn btn-ghost btn-block">Starten</button>
        <div id="warmup-pdf-progress" class="cache-progress">
          <div class="cache-progress-bar"></div>
        </div>
        <div id="warmup-pdf-result" class="cache-result-area"></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">PHP &amp; System</div>
  <div class="card-body" style="padding:0;">
    <table class="env-table">
      <thead>
        <tr>
          <th>Komponente</th>
          <th>Status</th>
          <th>Detail</th>
        </tr>
      </thead>
      <tbody>
        {% for key, check in section.environment %}
          <tr>
            <td style="font-weight:600;">{{ check.label }}</td>
            <td>
              <span class="status">
                <span class="status-dot {{ check.available ? 'status-ok' : 'status-fail' }}"></span>
                {{ check.available ? 'OK' : 'Fehlt' }}
              </span>
            </td>
            <td>{{ check.detail }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% if section.vinouPackages is defined and section.vinouPackages|length > 0 %}
<div class="card">
  <div class="card-header">Vinou-Pakete</div>
  <div class="card-body" style="padding:0;">
    <table class="env-table">
      <thead>
        <tr>
          <th>Paket</th>
          <th>Version</th>
        </tr>
      </thead>
      <tbody>
        {% for pkg in section.vinouPackages %}
          <tr>
            <td style="font-family:'SFMono-Regular',Consolas,monospace;font-size:0.8125rem;">{{ pkg.name }}</td>
            <td><span class="badge badge-get" style="font-size:0.75rem">{{ pkg.version }}</span></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}
